<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/dash" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="109dp"
        android:layout_marginBottom="42dp"
        android:text="Menu Principal"
        android:textColor="#020100"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/editPedido"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.543"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0" />

    <Button
        android:id="@+id/editGestion"
        android:layout_width="121dp"
        android:layout_height="55dp"
        android:layout_marginStart="74dp"
        android:layout_marginEnd="30dp"
        android:layout_marginBottom="26dp"
        android:backgroundTint="#9AFB8C00"
        android:text="Gestión de Productos"
        app:layout_constraintBottom_toTopOf="@+id/editIngresos"
        app:layout_constraintEnd_toStartOf="@+id/editSeguimiento"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editRegistrar" />

    <Button
        android:id="@+id/editIngresos"
        android:layout_width="117dp"
        android:layout_height="54dp"
        android:layout_marginStart="59dp"
        android:layout_marginEnd="30dp"
        android:layout_marginBottom="25dp"
        android:backgroundTint="#9AFB8C00"
        android:text="Ingresos y Egresos"
        app:layout_constraintBottom_toTopOf="@+id/editHistorial"
        app:layout_constraintEnd_toStartOf="@+id/editVentas"
        app:layout_constraintHorizontal_bias="0.692"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editGestion" />

    <Button
        android:id="@+id/editVentas"
        android:layout_width="123dp"
        android:layout_height="55dp"
        android:layout_marginStart="237dp"
        android:layout_marginEnd="36dp"
        android:layout_marginBottom="25dp"
        android:backgroundTint="#9AFB8C00"
        android:text="Ventas Mensuales"
        app:layout_constraintBottom_toTopOf="@+id/editMetodo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/editIngresos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editSeguimiento" />

    <Button
        android:id="@+id/editHistorial"
        android:layout_width="125dp"
        android:layout_height="54dp"
        android:layout_marginStart="84dp"
        android:layout_marginBottom="269dp"
        android:backgroundTint="#9AFB8C00"
        android:text="Historial Clientes"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editIngresos" />

    <Button
        android:id="@+id/editMetodo"
        android:layout_width="118dp"
        android:layout_height="55dp"
        android:layout_marginStart="238dp"
        android:layout_marginEnd="36dp"
        android:layout_marginBottom="33dp"
        android:backgroundTint="#9AFB8C00"
        android:text="Metodos de Pago"
        app:layout_constraintBottom_toTopOf="@+id/editConfig"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.708"
        app:layout_constraintStart_toEndOf="@+id/editHistorial"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editVentas" />

    <Button
        android:id="@+id/editSeguimiento"
        android:layout_width="132dp"
        android:layout_height="54dp"
        android:layout_marginStart="238dp"
        android:layout_marginEnd="36dp"
        android:layout_marginBottom="26dp"
        android:backgroundTint="#9AFB8C00"
        android:text="Seguimiento de Pedidos"
        app:layout_constraintBottom_toTopOf="@+id/editVentas"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/editGestion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editPedido" />

    <Button
        android:id="@+id/editPedido"
        android:layout_width="117dp"
        android:layout_height="57dp"
        android:layout_marginStart="245dp"
        android:layout_marginTop="180dp"
        android:layout_marginEnd="43dp"
        android:layout_marginBottom="13dp"
        android:backgroundTint="#9AFB8C00"
        android:text="Registrar pedido"
        app:layout_constraintBottom_toTopOf="@+id/editSeguimiento"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/editRegistrar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/editRegistrar"
        android:layout_width="121dp"
        android:layout_height="53dp"
        android:layout_marginStart="69dp"
        android:layout_marginTop="181dp"
        android:layout_marginEnd="43dp"
        android:layout_marginBottom="13dp"
        android:backgroundTint="#9AFB8C00"
        android:text="Registrar Cliente"
        app:layout_constraintBottom_toTopOf="@+id/editGestion"
        app:layout_constraintEnd_toStartOf="@+id/editPedido"
        app:layout_constraintHorizontal_bias="0.866"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/editConfig"
        android:layout_width="140dp"
        android:layout_height="47dp"
        android:layout_marginStart="67dp"
        android:layout_marginTop="502dp"
        android:layout_marginEnd="136dp"
        android:layout_marginBottom="182dp"
        android:backgroundTint="#9AFB8C00"
        android:text="Configuración"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0" />

</androidx.constraintlayout.widget.ConstraintLayout>